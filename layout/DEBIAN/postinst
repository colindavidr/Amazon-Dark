#!/bin/sh
# AmazonDark postinst
# No auto-killall/respring — learned from the CarBridgeReborn sessions that an
# automatic respring races the NathanLR/Ellekit dpkg triggers. The user force-quits
# and relaunches Amazon from the app switcher to activate.
echo "[AmazonDark] Installed. Force-quit and relaunch Amazon to activate."
echo "[AmazonDark] Tune it in Settings > AmazonDark."
# Remove stale PreferenceLoader entries from earlier layouts.
rm -f /var/jb/Library/PreferenceLoader/Preferences/AmazonDarkPrefs.plist 2>/dev/null || true
rm -f /Library/PreferenceLoader/Preferences/AmazonDarkPrefs.plist 2>/dev/null || true
exit 0
